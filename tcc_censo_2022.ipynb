        "\n",
        "    print(\"✅ Arquivos gerados com sucesso nas pastas data/processed e data/results!\")\n",
        "except Exception as e:\n",
        "    print(f\"❌ Erro ao exportar dados: {e}. Certifique-se de que as células de limpeza foram executadas.\")"
